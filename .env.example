# ─── Gemini AI DJ ─────────────────────────────────────────────────────────────
# Primary API Key (Google AI Studio)
GEMINI_API_KEY=your_gemini_api_key_here

# Optional: List of fallback API keys (comma-separated) to rotate when 
# quota is exhausted or errors (503/Timeout) occur.
GEMINI_API_KEYS_FALLBACK=key1,key2,key3

# ─── YouTube API ──────────────────────────────────────────────────────────────
# Get this from Google Cloud Console → APIs & Services → Credentials
YOUTUBE_API_KEY=your_youtube_api_key_here

# ─── Last.fm API ───────────────────────────────────────────────────────────────
# Free key from https://www.last.fm/api/account/create
LASTFM_API_KEY=your_lastfm_api_key_here

# ─── Admin Panel ──────────────────────────────────────────────────────────────
# Password for the admin panel at /admin.html
ADMIN_PASSWORD=changeme_to_something_secure

# ─── Content Filter ───────────────────────────────────────────────────────────
# Set to "true" to block explicit songs from search results and queue
BLOCK_EXPLICIT=true

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3000
