# ─── Spotify App Credentials ──────────────────────────────────────────────────
# Get these from https://developer.spotify.com/dashboard
SPOTIFY_CLIENT_ID=your_client_id_here
SPOTIFY_CLIENT_SECRET=your_client_secret_here

# ─── Redirect URI ─────────────────────────────────────────────────────────────
# Must match exactly what you set in Spotify Developer Dashboard
# For local dev:
REDIRECT_URI=http://localhost:3000/auth/callback
# For production (replace with your actual domain):
# REDIRECT_URI=https://yourdomain.com/auth/callback

# ─── Admin Panel ──────────────────────────────────────────────────────────────
# Password for the admin panel at /admin.html
ADMIN_PASSWORD=changeme_to_something_secure

# ─── Content Filter ───────────────────────────────────────────────────────────
# Set to "true" to block explicit songs from search results and queue
BLOCK_EXPLICIT=true

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3000
